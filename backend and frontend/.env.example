DATA_PATH=/app/data/id_mapping_v1.parquet
QUESTIONS_PATH=/app/data/questions.parquet
EMBEDDINGS_V1_PATH=/app/embeddings/embeddings_v1.npy
EMBEDDINGS_V2_PATH=/app/embeddings/embeddings_v2.npy
BM25_DIR=/app/index/bm25
SPLADE_DIR=/app/index/splade
USE_PRECOMPUTED_INDEXES=false
PRECOMPUTED_BM25S_DIR=/app/external_indexes/bm25s_cache
PRECOMPUTED_DENSE_DIR=/app/external_indexes/dense
PRECOMPUTED_SPLADE_DIR=/app/external_indexes/splade
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_V1=papers_v1
QDRANT_COLLECTION_V2=papers_v2
MODEL_V1=sentence-transformers/all-MiniLM-L6-v2
MODEL_V2=allenai/specter2
DENSE_QUERY_PREFIX=
DENSE_NORMALIZE_QUERY=true
DEVICE=cpu
SPLADE_MODEL=naver/splade-cocondenser-ensembledistil
SPLADE_MAX_LENGTH=374
SPLADE_THRESHOLD=0.01
SPLADE_BATCH_SIZE=32
SPLADE_QUERY_BATCH_SIZE=8
SPLADE_FP16=true
RERANKER_ENABLED=false
RERANKER_MODEL=mixedbread-ai/mxbai-rerank-large-v1
RERANKER_CANDIDATES=100
RERANKER_BATCH_SIZE=4
RERANKER_MAX_LENGTH=256
DEFAULT_MODE=triple_hybrid_v1
RRF_K=60
HNSW_EF_SEARCH=128
SEARCH_CANDIDATES=50
BM25S_STEMMER=russian
BM25S_STOPWORDS=ru
