DATA_PATH=data/id_mapping_v1.parquet
CHUNKS_PATH=data/chunks_fixed_v1.parquet
QUESTIONS_PATH=data/questions.parquet

USE_PRECOMPUTED_INDEXES=true
PRECOMPUTED_BM25S_DIR=external_indexes/bm25s_cache
PRECOMPUTED_DENSE_DIR=external_indexes/dense
PRECOMPUTED_SPLADE_DIR=external_indexes/splade

MODEL_V1=intfloat/multilingual-e5-small
DENSE_QUERY_PREFIX="query: "
DENSE_NORMALIZE_QUERY=true

SPLADE_MODEL=naver/splade-cocondenser-ensembledistil
SPLADE_MAX_LENGTH=374
SPLADE_THRESHOLD=0.01
SPLADE_QUERY_BATCH_SIZE=8

BM25S_STEMMER=russian
BM25S_STOPWORDS=ru

DEFAULT_MODE=triple_hybrid_v1
RRF_K=60
SEARCH_CANDIDATES=1000
DEVICE=cpu

RERANKER_ENABLED=false
RERANKER_MODEL=mixedbread-ai/mxbai-rerank-large-v1
RERANKER_CANDIDATES=1000
RERANKER_BATCH_SIZE=4
RERANKER_MAX_LENGTH=256
